{
  "name": "myappbase",
  "version": "1.0.0",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start",
    "prebuild": "expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web",
    "build:android:apk": "eas build -p android --profile preview --local",
    "build:android:aab": "eas build -p android --profile production --local",
    "build:ios:sim": "eas build -p ios --profile development --local",
    "build:ios:prod": "eas build -p ios --profile production --local"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.14",
    "@hookform/resolvers": "^5.4.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "^2.3.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query": "^5.100.13",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "expo": "^54.0.0",
    "expo-blur": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.18",
    "nativewind": "^5.0.0-preview.4",
    "postcss": "^8.5.15",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.76.0",
    "react-native": "0.81.5",
    "react-native-css": "^3.0.7",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "^1.21.8",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "^1.5.3",
    "react-native-toast-message": "^2.3.3",
    "react-native-worklets": "^0.8.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "~5.9.2"
  },
  "main": "expo-router/entry",
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "private": true
}
